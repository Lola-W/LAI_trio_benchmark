rule stage_panel_maps:
    input:
        sample_to_pop=META_SAMPLE_TO_POP,
        sample_to_superpop=META_SAMPLE_TO_SUPERPOP,
        sample_to_pop_superpop=META_POP_MAP,
        flare_panel=META_FLARE_PANEL,
        rfmix_map=META_RFMIX_MAP,
        gnomix_map=META_GNOMIX_MAP,
    output:
        common_pop=clean_path(f"{DATA_COMMON_DIR}/sample_to_population.tsv"),
        common_superpop=clean_path(f"{DATA_COMMON_DIR}/sample_to_superpopulation.tsv"),
        common_pop_superpop=clean_path(f"{DATA_COMMON_DIR}/sample_to_pop_superpop.tsv"),
        flare_panel=FLARE_PANEL,
        rfmix_map=RFMIX_SAMPLE_MAP,
        gnomix_map=GNOMIX_SAMPLE_MAP,
    shell:
        r"""
        mkdir -p {DATA_COMMON_DIR} {DATA_FLARE_TEST_DIR} {DATA_RFMIX_TEST_DIR} {DATA_GNOMIX_TEST_DIR}
        cp {input.sample_to_pop} {output.common_pop}
        cp {input.sample_to_superpop} {output.common_superpop}
        cp {input.sample_to_pop_superpop} {output.common_pop_superpop}
        cp {input.flare_panel} {output.flare_panel}
        cp {input.rfmix_map} {output.rfmix_map}
        cp {input.gnomix_map} {output.gnomix_map}
        """


rule build_test_lists:
    input:
        trios=META_TRIOS,
        pop_map=META_POP_MAP,
        staged=rules.stage_panel_maps.output.flare_panel,
    output:
        selected=SAMPLE_SELECTION_TSV,
        flare_query=FLARE_QUERY_FILES,
        rfmix_query=RFMIX_QUERY_FILES,
        gnomix_query=GNOMIX_QUERY_FILES,
        flare_trio=FLARE_TRIO_FILES,
        rfmix_trio=RFMIX_TRIO_FILES,
        gnomix_trio=GNOMIX_TRIO_FILES,
    run:
        with open(output.selected, "w") as f:
            f.write("trio_id\tchild\tfather\tmother\tpopulation\tsuperpopulation\n")
            for trio_id, child, father, mother in SELECTED_TRIOS:
                f.write(
                    "%s\t%s\t%s\t%s\t%s\t%s\n"
                    % (trio_id, child, father, mother, POPULATION, SUPERPOPULATION)
                )

        for trio_id, child, father, mother in SELECTED_TRIOS:
            for base_dir in [DATA_FLARE_TEST_DIR, DATA_RFMIX_TEST_DIR, DATA_GNOMIX_TEST_DIR]:
                child_dir = clean_path(f"{base_dir}/{child}")
                os.makedirs(child_dir, exist_ok=True)
                with open(clean_path(f"{child_dir}/query_child.test.txt"), "w") as qf:
                    qf.write(child + "\n")
                with open(clean_path(f"{child_dir}/trio.test.tsv"), "w") as tf:
                    tf.write("%s\t%s\t%s\t%s\n" % (trio_id, child, father, mother))


