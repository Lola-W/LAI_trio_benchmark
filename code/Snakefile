configfile: "snake_conf.yaml"

import os
import csv
import gzip
import re
from datetime import datetime
import yaml


def strip_hidden(v):
    # Drop invisible characters that often leak in from copy/paste.
    return str(v).replace("\ufeff", "").replace("\u200b", "")


def clean_str(v):
    return strip_hidden(v).strip()


def clean_token(v):
    # For path/name tokens, remove all whitespace (including accidental internal spaces).
    return re.sub(r"\s+", "", clean_str(v))


def clean_label(v):
    # Keep only safe filename token characters.
    s = clean_token(v)
    s = re.sub(r"[^A-Za-z0-9_.-]", "", s)
    if not s:
        raise ValueError("Invalid empty label after sanitization: %r" % (v,))
    return s


def clean_chrom(v):
    # Canonicalize to autosomal numeric chromosome token (e.g. "22").
    raw = clean_str(v)
    digits = "".join(ch for ch in raw if ch.isdigit())
    if not digits:
        # Fallback if value is like "chrX" or "X".
        s = clean_label(raw)
        s = re.sub(r"^(chr|CHR)", "", s)
        if s.upper() in {"X", "Y", "M", "MT"}:
            return s.upper()
        raise ValueError("Invalid chromosome value after sanitization: %r" % (v,))
    return str(int(digits))


def clean_path(v):
    # Normalize accidental whitespace around separators and remove any remaining whitespace.
    p = re.sub(r"\s*/\s*", "/", clean_str(v))
    p = re.sub(r"\s+", "", p)
    return p.rstrip("/")


ROOT_DIR = clean_path(config["root_dir"])
CHR = clean_chrom(config.get("chromosome", "22"))
THREADS_CFG = config.get("threads", {})
