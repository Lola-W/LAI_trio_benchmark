rule combine_child_results:
    input:
        selected=SAMPLE_SELECTION_TSV,
        flare_global=FLARE_GLOBAL_TEMPLATE,
        flare_anc=FLARE_ANC_TEMPLATE,
        rfmix_msp=RFMIX_MSP_TEMPLATE,
        rfmix_fb=RFMIX_FB_TEMPLATE,
        gnomix_msp=GNOMIX_MSP_TEMPLATE,
        gnomix_fb=GNOMIX_FB_TEMPLATE,
    output:
        summary=CHILD_SUMMARY_TEMPLATE,
        paths=CHILD_PATHS_TEMPLATE,
    run:
        child = clean_label(wildcards.child)
        os.makedirs(os.path.dirname(output.summary), exist_ok=True)

        selected_rows = {}
        with open(input.selected, "r") as f:
            reader = csv.DictReader(f, delimiter="\t")
            for row in reader:
                selected_rows[clean_label(row["child"])] = row
        if child not in selected_rows:
            raise ValueError("Child %s is not present in %s" % (child, input.selected))

        flare_best_anc = "NA"
        flare_best_score = -1.0
        with gzip.open(input.flare_global, "rt") as f:
            reader = csv.DictReader(f, delimiter="\t")
            anc_cols = [c for c in reader.fieldnames if c != "SAMPLE"]
            rows = list(reader)
            if rows:
                row = rows[0]
                flare_best_anc = max(anc_cols, key=lambda a: float(row[a]))
                flare_best_score = float(row[flare_best_anc])

        def msp_data_rows(path):
            opener = gzip.open if path.endswith(".gz") else open
            with opener(path, "rt") as f:
                header_seen = False
                n_rows = 0
                for line in f:
                    if line.startswith("#"):
                        continue
                    if not header_seen:
                        header_seen = True
                        continue
                    if line.strip():
                        n_rows += 1
                return n_rows

        rfmix_rows = msp_data_rows(input.rfmix_msp)
        gnomix_rows = msp_data_rows(input.gnomix_msp)

        now = datetime.now().isoformat(timespec="seconds")
        with open(output.summary, "w") as f:
            f.write(
                "timestamp\tsample_id\ttool\tchromosome\tstatus\tprediction\tprediction_score\tdata_rows\tresult_file\n"
            )
            f.write(
                "%s\t%s\tFLARE\tchr%s\tOK\t%s\t%s\tNA\t%s\n"
                % (now, child, CHR, flare_best_anc, flare_best_score, input.flare_anc)
            )
            f.write(
                "%s\t%s\tRFMix\tchr%s\tOK\tNA\tNA\t%s\t%s\n"
                % (now, child, CHR, rfmix_rows, input.rfmix_msp)
            )
            f.write(
                "%s\t%s\tGnomix\tchr%s\tOK\tNA\tNA\t%s\t%s\n"
                % (now, child, CHR, gnomix_rows, input.gnomix_msp)
            )

        with open(output.paths, "w") as f:
            f.write("CHILD=%s\n" % child)
            f.write("FLARE_ANC=%s\n" % input.flare_anc)
            f.write("FLARE_GLOBAL=%s\n" % input.flare_global)
            f.write("RFMIX_MSP=%s\n" % input.rfmix_msp)
            f.write("RFMIX_FB=%s\n" % input.rfmix_fb)
            f.write("GNOMIX_MSP=%s\n" % input.gnomix_msp)
            f.write("GNOMIX_FB=%s\n" % input.gnomix_fb)


rule combine_tool_results:
    input:
        selected=SAMPLE_SELECTION_TSV,
        child_summaries=CHILD_SUMMARY_FILES,
        child_paths=CHILD_PATH_FILES,
    output:
        summary=COMBINED_TSV,
        paths=COMBINED_TXT,
    run:
        os.makedirs(os.path.dirname(output.summary), exist_ok=True)

        with open(output.summary, "w") as out:
            wrote_header = False
            for child_summary in input.child_summaries:
                with open(child_summary, "r") as f:
                    for idx, line in enumerate(f):
                        if idx == 0:
                            if not wrote_header:
                                out.write(line)
                                wrote_header = True
                        else:
                            out.write(line)

        with open(output.paths, "w") as out:
            out.write("chromosome=chr%s\n" % CHR)
            out.write("n_children=%d\n" % len(TARGET_CHILDREN))
            out.write("children=%s\n" % ",".join(TARGET_CHILDREN))
            out.write("\n")
            for child_path in input.child_paths:
                out.write("## %s\n" % child_path)
                with open(child_path, "r") as f:
                    for line in f:
                        out.write(line)
                out.write("\n")
