def load_child_to_trio(path):
    child_to_trio = {}
    with open(path, "r") as f:
        for row in csv.reader(f, delimiter="\t"):
            if not row or row[0].startswith("#"):
                continue
            if len(row) < 4:
                continue
            trio_id, child, father, mother = row[:4]
            child_to_trio[clean_label(child)] = (
                clean_label(trio_id),
                clean_label(child),
                clean_label(father),
                clean_label(mother),
            )
    return child_to_trio


def select_trios_for_test():
    child_to_trio = load_child_to_trio(META_TRIOS)
    eligible = []
    with open(META_POP_MAP, "r") as f:
        reader = csv.DictReader(f, delimiter="\t")
        for row in reader:
            sid = clean_label(row["sample_id"])
            if sid not in child_to_trio:
                continue
            if (
                clean_label(row["population"]) == POPULATION
                and clean_label(row["superpopulation"]) == SUPERPOPULATION
            ):
                eligible.append(sid)

    if not eligible:
        raise ValueError(
            "No eligible child samples found for %s/%s." % (POPULATION, SUPERPOPULATION)
        )

    chosen = []
    eligible_set = set(eligible)

    for sid in SEED_SAMPLES:
        if sid not in eligible_set:
            raise ValueError(
                "Seed sample %s is not eligible for %s/%s child-only masking."
                % (sid, POPULATION, SUPERPOPULATION)
            )
        if sid not in chosen:
            chosen.append(sid)

    for sid in sorted(eligible):
        if sid not in chosen:
            chosen.append(sid)
        if len(chosen) >= N_SAMPLES:
            break

    if len(chosen) < N_SAMPLES:
        raise ValueError(
            "Requested %d samples but only found %d eligible %s/%s children with complete trios."
            % (N_SAMPLES, len(chosen), POPULATION, SUPERPOPULATION)
        )

    return [child_to_trio[sid] for sid in chosen]


SELECTED_TRIOS = select_trios_for_test()
TARGET_CHILDREN = [x[1] for x in SELECTED_TRIOS]

FLARE_QUERY_FILES = expand(FLARE_QUERY_TEMPLATE, child=TARGET_CHILDREN)
