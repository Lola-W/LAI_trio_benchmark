rule run_flare:
    input:
        script=RUN_FLARE_SCRIPT,
        raw_vcf=RAW_VCF,
        query=FLARE_QUERY_TEMPLATE,
        trio=FLARE_TRIO_TEMPLATE,
        panel=FLARE_PANEL,
        map=MAP_FLARE,
    output:
        anc=FLARE_ANC_TEMPLATE,
        global_anc=FLARE_GLOBAL_TEMPLATE,
        model=FLARE_MODEL_TEMPLATE,
        log=FLARE_LOG_TEMPLATE,
    threads: int(THREADS_CFG.get("flare", 8))
    params:
        mem_gb=int(MEM_CFG.get("flare", 64)),
        work_dir=lambda wc: clean_path(f"{ROOT_DIR}/work/FLARE/chr{CHR}/{wc.child}"),
        out_prefix=lambda wc: clean_path(
            f"{ROOT_DIR}/out/FLARE/child_only_population/chr{CHR}/{wc.child}/test_chr{CHR}"
        ),
    resources:
        mem_mb=int(MEM_CFG.get("flare", 64)) * 1024
    shell:
        r"""
        QUERY_LIST={input.query} \
        REF_PANEL={input.panel} \
        LAI_ENV_PREFIX={LAI_ENV_PREFIX} \
        WORK_DIR={params.work_dir} \
        OUT_PREFIX={params.out_prefix} \
        FLARE_MEM_GB={params.mem_gb} \
        bash {input.script} {CHR} {threads}
        """


