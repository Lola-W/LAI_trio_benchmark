for _k, _v in {
    "ROOT_DIR": ROOT_DIR,
    "CHR": CHR,
    "POPULATION": POPULATION,
    "SUPERPOPULATION": SUPERPOPULATION,
}.items():
    if any(ch.isspace() for ch in _v):
        raise ValueError("%s still contains whitespace after sanitization: %r" % (_k, _v))

if MASKING_MODE != "child_only":
    raise ValueError("This workflow currently supports masking_mode=child_only only.")

